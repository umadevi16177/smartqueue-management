# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-public-url.example.com/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=change_me_to_a_random_string

# LLM provider — ollama | anthropic | none (heuristic only)
LLM_PROVIDER=ollama

# Ollama (local — default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Anthropic (only used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL_FAST=claude-haiku-4-5
ANTHROPIC_MODEL_REASONING=claude-sonnet-4-6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
# PostgreSQL — tables live under the `smartqueue` schema, created
# automatically by app.db.init_db(). SQLAlchemy-style `postgresql+psycopg2://`
# URLs are accepted (the +psycopg2 hint is stripped).
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/smartqueue
ADMIN_PASSWORD=change_me

# Hospital
HOSPITAL_NAME=City General Hospital
DEFAULT_LANGUAGE=en
